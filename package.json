{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub PR to project brief generator.",
  "scripts": {
    "brief": "tsx src/cli/main.ts brief",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
