generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum GroupVisibility {
  PUBLIC
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

enum MatchTeam {
  TEAM_A
  TEAM_B
}

enum MatchProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum GroupRankingProjectionStatus {
  CURRENT
  PROCESSING
  FAILED
}

enum RankingMovementDirection {
  UP
  DOWN
}

enum ProcessingJobType {
  MATCH_CREATED
  MATCH_UPDATED
  MATCH_DELETED
  GROUP_RANKING_REBUILD
  // Deprecated: platform-trending was retired. Kept to avoid a fragile enum-value removal.
  PLATFORM_TRENDING_PLAYERS_REBUILD
}

enum ProcessingJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ProcessingJobScope {
  GROUP
  // Deprecated: platform-trending was retired. Kept to avoid a fragile enum-value removal.
  PLATFORM
}

enum FeedItemType {
  GROUP_CREATED
  MEMBER_JOINED
  MATCH_CLOSE
  MATCH_BLOWOUT
  UPSET_WIN
  RANKING_MOVEMENT
}

enum FeedItemScope {
  GROUP
  USER
}

enum FeedItemVisibility {
  GROUP_MEMBERS
  SOCIAL_CIRCLE
  PUBLIC
  PRIVATE
}

model User {
  id           String @id @default(uuid())
  firstName    String
  lastName     String
  email        String @unique
  passwordHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdGroups           Group[]                 @relation("GroupCreator")
  memberships             GroupMember[]
  createdInvites          GroupInvite[]           @relation("GroupInviteCreator")
  actorFeedItems          FeedItem[]              @relation("FeedItemActorUser")
  subjectFeedItems        FeedItem[]              @relation("FeedItemSubjectUser")
  groupHighlights         GroupHighlight[]

  @@index([email])
}

model Group {
  id          String          @id @default(uuid())
  name        String
  description String?
  visibility  GroupVisibility @default(PUBLIC)

  createdById String
  createdBy   User   @relation("GroupCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members                 GroupMember[]
  matches                 Match[]
  invites                 GroupInvite[]
  feedItems               FeedItem[]
  rankingMovements        RankingMovement[]
  processingJobs          ProcessingJob[]
  rankingProjection       GroupRankingProjection?
  matchRankingSnapshots   MatchRankingSnapshot[]
  homeSummary             GroupHomeSummary?
  memberStats             GroupMemberStats[]
  groupHighlights         GroupHighlight[]


  @@index([visibility, createdAt])
  @@index([name])
  @@index([createdById])
}

model GroupInvite {
  id String @id @default(uuid())

  token String @unique

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("GroupInviteCreator", fields: [createdById], references: [id])

  expiresAt DateTime?
  revokedAt DateTime?

  uses    Int  @default(0)
  maxUses Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([createdById])
  @@index([token])
}

model GroupMember {
  id String @id @default(uuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating           Float  @default(1000)
  ratingDeviation  Float?
  ratingVolatility Float?
  ratingMu         Float?
  ratingSigma      Float?
  ratingAlgorithm  String @default("BEACH_ELO_V1")
  currentRank      Int?

  role GroupMemberRole @default(MEMBER)

  leftAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchPlayers          MatchPlayer[]
  actorFeedItems        FeedItem[]          @relation("FeedItemActorGroupMember")
  rankingMovements      RankingMovement[]
  stats                 GroupMemberStats?
  groupHighlights         GroupHighlight[]

  @@unique([groupId, userId])
  @@unique([id, groupId])
  @@index([groupId])
  @@index([userId])
  @@index([groupId, rating])
  @@index([groupId, currentRank, rating])
  @@index([groupId, role])
}

model GroupMemberStats {
  groupMemberId String @id
  groupId       String

  matchesCount Int @default(0)
  winsCount    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupMember GroupMember @relation(fields: [groupMemberId, groupId], references: [id, groupId], onDelete: Cascade)

  @@unique([groupMemberId, groupId])
  @@index([groupId])
  @@index([groupId, matchesCount])
}

enum HighlightType {
  WIN_STREAK_CURRENT
  WIN_STREAK_RECORD
  CLIMB
  LEADERSHIP
  MILESTONE_MATCHES
  MILESTONE_WINS
}

// Derived read model (rebuilt by the weekly-highlights projection in the GROUP cascade,
// never hand-edited). One row per (groupMember, type); the 7-day window is applied at read time.
model GroupHighlight {
  id String @id @default(uuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  groupMemberId String
  groupMember   GroupMember @relation(fields: [groupMemberId, groupId], references: [id, groupId], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     HighlightType
  value    Int
  score    Float
  anchorAt DateTime

  algorithmVersion String @default("WEEKLY_HIGHLIGHTS_V1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupMemberId, type])
  @@index([groupId, anchorAt])
  @@index([score])
  @@index([userId, anchorAt])
}

model Match {
  id String @id @default(uuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  gamesA Int
  gamesB Int

  winnerTeam MatchTeam?

  teamAExpected Float?
  teamBExpected Float?
  teamAActual   Float?
  teamBActual   Float?

  teamARatingBefore Float?
  teamBRatingBefore Float?
  teamARatingAfter  Float?
  teamBRatingAfter  Float?

  ratingAlgorithm String @default("BEACH_ELO_V1")

  processingStatus MatchProcessingStatus @default(PROCESSED)
  processedAt      DateTime?
  processingError   String?
  deletedAt         DateTime?

  playedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  players          MatchPlayer[]
  feedItems        FeedItem[]
  rankingMovements RankingMovement[]
  rankingSnapshot  MatchRankingSnapshot?
  processingJobs   ProcessingJob[]

  @@unique([id, groupId])
  @@index([groupId])
  @@index([groupId, playedAt, createdAt])
  @@index([groupId, winnerTeam])
  @@index([groupId, ratingAlgorithm])
  @@index([groupId, processingStatus])
  @@index([groupId, deletedAt])
}

model MatchPlayer {
  id String @id @default(uuid())

  matchId String
  groupId String

  match Match @relation(fields: [matchId, groupId], references: [id, groupId], onDelete: Cascade)

  groupMemberId String
  groupMember   GroupMember @relation(fields: [groupMemberId, groupId], references: [id, groupId], onDelete: Restrict)

  team     MatchTeam
  position Int

  ratingBefore Float
  ratingAfter  Float
  ratingDelta  Float

  rankBefore Int?
  rankAfter  Int?
  rankDelta  Int?

  movementDirection RankingMovementDirection?
  movementPositions Int?

  ratingDeviationBefore  Float?
  ratingDeviationAfter   Float?
  ratingVolatilityBefore Float?
  ratingVolatilityAfter  Float?

  ratingMuBefore    Float?
  ratingMuAfter     Float?
  ratingSigmaBefore Float?
  ratingSigmaAfter  Float?

  playedAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, groupMemberId])
  @@unique([matchId, team, position])
  @@index([matchId])
  @@index([groupId])
  @@index([groupId, playedAt])
  @@index([groupId, groupMemberId])
  @@index([groupId, groupMemberId, playedAt])
  @@index([groupMemberId])
  @@index([groupMemberId, playedAt])
  @@index([groupId, rankBefore, rankAfter])
}

model MatchRankingSnapshot {
  matchId String @id
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  previousLeaders  Json @default("[]")
  currentLeaders   Json @default("[]")
  dethronedLeaders Json @default("[]")
  movements        Json @default("[]")

  algorithmVersion String @default("BEACH_ELO_V1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([algorithmVersion])
}

model GroupRankingProjection {
  groupId String @id
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  status GroupRankingProjectionStatus @default(CURRENT)
  version Int @default(0)

  processingJobId String?
  lastProcessedMatchId String?
  lastProcessedAt DateTime?
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([lastProcessedAt])
}

model GroupHomeSummary {
  groupId String @id
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  membersCount Int @default(0)
  leaders      Json @default("[]")

  lastRelevantFeedItemId String?
  lastRelevantFeedItem   FeedItem? @relation("GroupHomeSummaryLastRelevantFeedItem", fields: [lastRelevantFeedItemId], references: [id], onDelete: SetNull)
  lastRelevantAt         DateTime?

  projectionStatus GroupRankingProjectionStatus?
  lastProcessedAt  DateTime?
  lastError        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastRelevantAt])
  @@index([projectionStatus])
}

model RankingMovement {
  id String @id @default(uuid())

  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  groupMemberId String
  groupMember   GroupMember @relation(fields: [groupMemberId, groupId], references: [id, groupId], onDelete: Cascade)

  matchId String
  match   Match  @relation(fields: [matchId, groupId], references: [id, groupId], onDelete: Cascade)

  direction RankingMovementDirection
  positions Int

  previousRank Int
  currentRank  Int

  previousRating Float
  currentRating  Float

  passedGroupMemberIds Json @default("[]")

  isVisible     Boolean   @default(false)
  occurredAt    DateTime
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([matchId, groupMemberId])
  @@index([groupId, occurredAt])
  @@index([groupMemberId, occurredAt])
  @@index([matchId])
  @@index([groupId, isVisible])
}

model ProcessingJob {
  id String @id @default(uuid())

  type   ProcessingJobType
  scope  ProcessingJobScope @default(GROUP)
  status ProcessingJobStatus @default(PENDING)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  matchId String?
  match   Match?  @relation(fields: [matchId, groupId], references: [id, groupId], onDelete: Cascade)

  dedupeKey String?
  payload Json @default("{}")

  attemptCount Int @default(0)
  maxAttempts  Int @default(5)

  availableAt DateTime @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, availableAt])
  @@index([scope, status, availableAt])
  @@index([groupId, status, createdAt])
  @@index([matchId])
  @@index([dedupeKey])
  @@index([lockedBy])
}

model FeedItem {
  id String @id @default(uuid())

  type       FeedItemType
  scope      FeedItemScope
  visibility FeedItemVisibility

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation("FeedItemActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  actorGroupMemberId String?
  actorGroupMember   GroupMember? @relation("FeedItemActorGroupMember", fields: [actorGroupMemberId], references: [id], onDelete: SetNull)

  subjectUserId String?
  subjectUser   User?   @relation("FeedItemSubjectUser", fields: [subjectUserId], references: [id], onDelete: Cascade)

  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  groupHomeSummaries GroupHomeSummary[] @relation("GroupHomeSummaryLastRelevantFeedItem")

  importanceScore Int @default(0)

  metadata Json

  occurredAt DateTime
  createdAt  DateTime @default(now())

  @@unique([type, matchId])
  @@index([scope, occurredAt])
  @@index([visibility, occurredAt])
  @@index([groupId, occurredAt])
  @@index([type, occurredAt])
  @@index([importanceScore, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([subjectUserId, occurredAt])
  @@index([actorGroupMemberId, occurredAt])
  @@index([matchId])
}
